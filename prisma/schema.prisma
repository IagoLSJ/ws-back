generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleNegocio {
  SUPER_ADMIN
  GERENTE
  OPERADOR
  VISUALIZADOR
}

enum ProdutoStatus {
  ATIVO
  PAUSADO
  ESGOTADO
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA_VENDA
  SAIDA_AJUSTE
  PERDA
  TRANSFERENCIA_ENTRADA
  TRANSFERENCIA_SAIDA
  INVENTARIO
}

enum StatusPedido {
  PENDENTE
  CONFIRMADO
  PREPARANDO
  PRONTO
  SAIU_PARA_ENTREGA
  ENTREGUE
  CANCELADO
}

enum TipoMensagemWhatsApp {
  CLIENTE
  BOT
  ADMIN
}

enum MetodoPagamento {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  CREDIARIO
  OUTRO
}

enum StatusPagamento {
  PENDENTE
  APROVADO
  RECUSADO
  CANCELADO
  ESTORNADO
}

enum TipoMovimentoCaixa {
  ABERTURA
  FECHAMENTO
  SANGRIA
  SUPRIMENTO
  PAGAMENTO
}

enum TipoNegocio {
  VAREJO
  COMIDA
  SERVICO
}

enum TipoEntrega {
  ENTREGA
  RETIRADA
  MESA
}

model Usuario {
  id            String   @id @default(uuid())
  nome          String
  email         String   @unique
  senhaHash     String
  avatarUrl     String?
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  membros        MembroNegocio[]
  tokens         RefreshToken[]
  movimentacoes  MovimentacaoEstoque[]
  pedidos        Pedido[]
  carrinhos      Carrinho[]
  auditLogs      AuditLog[]
  caixasAbertura   Caixa[]        @relation("CaixaAbertura")
  caixasOperador   Caixa[]        @relation("CaixaOperador")
  caixasFechamento Caixa[]        @relation("CaixaFechamento")

  @@map("usuarios")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  usuarioId  String
  expiresAt  DateTime
  revogado   Boolean  @default(false)
  criadoEm   DateTime @default(now())

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Negocio {
  id            String      @id @default(uuid())
  nome          String
  slug          String      @unique
  descricao     String?
  logoUrl       String?
  bannerUrl     String?
  corPrimaria   String?
  tipo          TipoNegocio @default(VAREJO)
  ativo         Boolean     @default(true)
  criadoEm      DateTime    @default(now())
  atualizadoEm  DateTime    @updatedAt

  membros           MembroNegocio[]
  categorias        Categoria[]
  produtos          Produto[]
  estoques          EstoqueItem[]
  movimentacoes     MovimentacaoEstoque[]
  carrinhos         Carrinho[]
  pedidos           Pedido[]
  clientesWhatsapp  ClienteWhatsApp[]
  configuracoes     ConfiguracaoNegocio?
  taxasFreteBairro  TaxaFreteBairro[]
  impressoras       ImpressoraConfig[]
  caixas            Caixa[]
  mesas             Mesa[]
  contasReceber     ContaReceber[]

  @@map("negocios")
}

model ConfiguracaoNegocio {
  id                    String    @id @default(uuid())
  negocioId             String    @unique
  controleEstoqueAtivo  Boolean   @default(true)
  estoqueMinimoPadrao   Int       @default(5)
  taxaFrete             Decimal   @default(0) @db.Decimal(10, 2)
  webhookUrl            String?
  emailAlertas          String?
  horarioFuncionamento  Json?
  endereco              Json?
  telefoneContato       String?
  chatbotAtivo          Boolean   @default(true)
  mensagemBoasVindas    String?
  mensagemFallback      String?
  cnpj                  String?
  ie                    String?
  razaoSocial           String?

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@map("configuracoes_negocio")
}

model TaxaFreteBairro {
  id        String   @id @default(uuid())
  negocioId String
  bairro    String
  taxa      Decimal  @default(0) @db.Decimal(10, 2)
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  negocio   Negocio  @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([negocioId, bairro])
  @@index([negocioId, ativo])
  @@map("taxas_frete_bairro")
}

model ImpressoraConfig {
  id            String   @id @default(uuid())
  negocioId     String
  tipo          String   @default("TERMICA")
  conexao       String   @default("USB")
  enderecoIp    String?
  porta         Int      @default(9100)
  papelLargura  Int      @default(80)
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@index([negocioId, ativo])
  @@map("impressoras_config")
}

model Caixa {
  id                    String   @id @default(uuid())
  negocioId             String
  usuarioAberturaId     String
  operadorId            String?
  usuarioFechamentoId   String?
  saldoInicial          Decimal  @default(0) @db.Decimal(10, 2)
  saldoFinal            Decimal? @db.Decimal(10, 2)
  totalTroco            Decimal  @default(0) @db.Decimal(10, 2)
  totalVendas           Decimal  @default(0) @db.Decimal(10, 2)
  totalDinheiro         Decimal  @default(0) @db.Decimal(10, 2)
  totalDebito           Decimal  @default(0) @db.Decimal(10, 2)
  totalCredito          Decimal  @default(0) @db.Decimal(10, 2)
  totalPix              Decimal  @default(0) @db.Decimal(10, 2)
  totalOutros           Decimal  @default(0) @db.Decimal(10, 2)
  totalSangrias         Decimal  @default(0) @db.Decimal(10, 2)
  totalSuprimentos      Decimal  @default(0) @db.Decimal(10, 2)
  dataAbertura          DateTime @default(now())
  dataFechamento        DateTime?
  status                String   @default("ABERTO")
  observacao            String?

  negocio           Negocio           @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  usuarioAbertura   Usuario           @relation("CaixaAbertura", fields: [usuarioAberturaId], references: [id])
  operador          Usuario?          @relation("CaixaOperador", fields: [operadorId], references: [id])
  usuarioFechamento Usuario?          @relation("CaixaFechamento", fields: [usuarioFechamentoId], references: [id])
  movimentos        CaixaMovimento[]

  @@index([negocioId, status])
  @@map("caixas")
}

model CaixaMovimento {
  id              String             @id @default(uuid())
  caixaId         String
  tipo            TipoMovimentoCaixa
  valor           Decimal            @db.Decimal(10, 2)
  formaPagamento  String?
  pedidoId        String?
  descricao       String?
  criadoEm        DateTime           @default(now())

  caixa Caixa @relation(fields: [caixaId], references: [id], onDelete: Cascade)

  @@index([caixaId])
  @@map("caixa_movimentos")
}

model Mesa {
  id           String   @id @default(uuid())
  negocioId    String
  numero       Int
  nome         String?
  status       String   @default("LIVRE")
  ativa        Boolean  @default(true)
  sessionId    String?
  qrCodeToken  String   @unique
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  negocio  Negocio    @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  pedidos  Pedido[]
  carrinhos Carrinho[]

  @@unique([negocioId, numero])
  @@index([negocioId, status])
  @@map("mesas")
}

model MembroNegocio {
  id         String       @id @default(uuid())
  usuarioId  String
  negocioId  String
  role       RoleNegocio
  ativo      Boolean      @default(true)
  criadoEm   DateTime     @default(now())

  usuario    Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  negocio    Negocio      @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, negocioId])
  @@index([negocioId])
  @@map("membros_negocio")
}

model Categoria {
  id         String    @id @default(uuid())
  negocioId  String
  nome       String
  descricao  String?
  iconUrl    String?
  ordem      Int       @default(0)
  ativo      Boolean   @default(true)
  criadoEm   DateTime  @default(now())

  negocio    Negocio   @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  produtos   Produto[]

  @@unique([negocioId, nome])
  @@index([negocioId, ativo])
  @@map("categorias")
}

model Produto {
  id                   String         @id @default(uuid())
  negocioId            String
  categoriaId          String?
  nome                 String
  descricao            String?
  preco                Decimal        @db.Decimal(10, 2)
  tipoDesconto         String?
  valorDesconto        Decimal?       @db.Decimal(10, 2)
  sku                  String?
  codigoBarras         String?
  plu                  Int?
  precoCusto           Decimal?       @db.Decimal(10, 2)
  status               ProdutoStatus  @default(ATIVO)
  destaque             Boolean        @default(false)
  ordem                Int            @default(0)
  controlaEstoque      Boolean        @default(true)
  vendaPorPeso         Boolean        @default(false)
  unidadeMedida        String         @default("un")
  criadoEm             DateTime       @default(now())
  atualizadoEm         DateTime       @updatedAt

  negocio              Negocio           @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  categoria            Categoria?        @relation(fields: [categoriaId], references: [id])
  imagens              ImagemProduto[]
  gruposModificadores  GrupoModificador[]
  estoqueItem          EstoqueItem?
  carrinhoItens        CarrinhoItem[]
  pedidoItens          PedidoItem[]

  @@unique([negocioId, plu])
  @@index([negocioId, status])
  @@index([negocioId, categoriaId])
  @@map("produtos")
}

model ImagemProduto {
  id         String  @id @default(uuid())
  produtoId  String
  url        String
  ordem      Int     @default(0)
  principal  Boolean @default(false)

  produto    Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@map("imagens_produto")
}

model GrupoModificador {
  id          String   @id @default(uuid())
  produtoId   String
  nome        String
  obrigatorio Boolean  @default(false)
  minSelecao  Int      @default(0)
  maxSelecao  Int      @default(1)
  ordem       Int      @default(0)

  produto     Produto           @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  opcoes      OpcaoModificador[]

  @@map("grupos_modificador")
}

model OpcaoModificador {
  id         String   @id @default(uuid())
  grupoId    String
  nome       String
  precoExtra Decimal  @default(0) @db.Decimal(10, 2)
  ativo      Boolean  @default(true)
  ordem      Int      @default(0)

  grupo              GrupoModificador @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  carrinhoItemOpcoes CarrinhoItemOpcao[]

  @@map("opcoes_modificador")
}

model EstoqueItem {
  id              String          @id @default(uuid())
  negocioId       String
  produtoId       String?         @unique
  nome            String?
  sku             String?
  precoCusto      Decimal?        @db.Decimal(10, 2)
  quantidadeAtual Int             @default(0)
  estoqueMinimo   Int             @default(5)
  unidade         String          @default("un")
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt

  negocio          Negocio               @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  produto          Produto?              @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  movimentacoes    MovimentacaoEstoque[]

  @@index([negocioId])
  @@map("estoque_itens")
}

model MovimentacaoEstoque {
  id              String             @id @default(uuid())
  negocioId       String
  estoqueItemId   String
  usuarioId       String?
  tipo            TipoMovimentacao
  quantidade      Int
  quantidadeAntes Int
  quantidadeApos  Int
  motivo          String?
  referencia      String?
  criadoEm        DateTime           @default(now())

  negocio         Negocio            @relation(fields: [negocioId], references: [id])
  estoqueItem     EstoqueItem        @relation(fields: [estoqueItemId], references: [id])
  usuario         Usuario?           @relation(fields: [usuarioId], references: [id])

  @@index([negocioId, criadoEm])
  @@index([estoqueItemId, criadoEm])
  @@map("movimentacoes_estoque")
}

model AuditLog {
  id         String   @id @default(uuid())
  usuarioId  String?
  negocioId  String?
  acao       String
  entidade   String?
  entidadeId String?
  payload    Json?
  ip         String?
  userAgent  String?
  criadoEm   DateTime @default(now())

  usuario    Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([negocioId, criadoEm])
  @@index([usuarioId, criadoEm])
  @@map("audit_logs")
}

model ClienteWhatsApp {
  id              String   @id @default(uuid())
  negocioId       String
  telefone        String
  sessionId       String   @unique
  nome            String?
  endereco        Json?    @db.Json
  modoHumano      Boolean  @default(false)
  ultimaInteracao DateTime @default(now())
  criadoEm        DateTime @default(now())

  negocio  Negocio           @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  mensagens MensagemWhatsApp[]

  @@unique([negocioId, telefone])
  @@index([negocioId, telefone])
  @@map("clientes_whatsapp")
}

model MensagemWhatsApp {
  id         String               @id @default(uuid())
  clienteId  String
  texto      String
  tipo       TipoMensagemWhatsApp
  criadoEm   DateTime             @default(now())

  cliente    ClienteWhatsApp      @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, criadoEm])
  @@map("mensagens_whatsapp")
}

model Carrinho {
  id         String   @id @default(uuid())
  negocioId  String
  sessionId  String
  usuarioId  String?
  mesaId     String?
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  negocio    Negocio       @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  usuario    Usuario?      @relation(fields: [usuarioId], references: [id])
  mesa       Mesa?         @relation(fields: [mesaId], references: [id], onDelete: SetNull)
  itens      CarrinhoItem[]

  @@unique([negocioId, sessionId])
  @@index([negocioId, sessionId])
  @@map("carrinhos")
}

model CarrinhoItem {
  id         String   @id @default(uuid())
  carrinhoId String
  produtoId  String
  quantidade Decimal  @default(1) @db.Decimal(10, 3)
  observacao String?
  criadoEm   DateTime @default(now())

  carrinho           Carrinho                      @relation(fields: [carrinhoId], references: [id], onDelete: Cascade)
  produto            Produto                       @relation(fields: [produtoId], references: [id])
  opcoesSelecionadas CarrinhoItemOpcao[]

  @@index([carrinhoId])
  @@map("carrinho_itens")
}

model CarrinhoItemOpcao {
  id            String @id @default(uuid())
  carrinhoItemId String
  opcaoId        String

  carrinhoItem CarrinhoItem      @relation(fields: [carrinhoItemId], references: [id], onDelete: Cascade)
  opcao        OpcaoModificador  @relation(fields: [opcaoId], references: [id])

  @@unique([carrinhoItemId, opcaoId])
  @@map("carrinho_itens_opcoes")
}

model Cliente {
  id            String   @id @default(uuid())
  cpfCnpj       String   @unique
  nome          String
  telefone      String?
  limiteCredito Decimal  @default(0) @db.Decimal(10, 2)
  saldoDevedor  Decimal  @default(0) @db.Decimal(10, 2)
  observacao    String?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  contasReceber ContaReceber[]
  pedidos       Pedido[]

  @@map("clientes")
}

model ContaReceber {
  id             String            @id @default(uuid())
  clienteId      String
  negocioId      String
  pedidoId       String
  valorTotal     Decimal           @db.Decimal(10, 2)
  valorPago      Decimal           @default(0) @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         ContaReceberStatus @default(PENDENTE)
  observacao     String?
  criadoEm       DateTime          @default(now())
  atualizadoEm   DateTime          @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id])
  negocio Negocio @relation(fields: [negocioId], references: [id])
  pedido  Pedido  @relation(fields: [pedidoId], references: [id])

  @@index([clienteId])
  @@index([negocioId, status])
  @@map("contas_receber")
}

enum ContaReceberStatus {
  PENDENTE
  PARCIAL
  PAGO
  ATRASADO
}

model Pedido {
  id             String       @id @default(uuid())
  negocioId      String
  sessionId      String
  usuarioId      String?
  status         StatusPedido @default(PENDENTE)
  total          Decimal      @db.Decimal(10, 2)
  tipoEntrega    TipoEntrega  @default(ENTREGA)
  taxaFrete      Decimal?     @db.Decimal(10, 2)
  observacao     String?
  endereco       Json?        @db.Json
  contato        String?
  agendadoPara        DateTime?
  clienteId           String?
  clienteCpf          String?
  clienteNome         String?
  chaveAcesso         String?
  qrCodeUrl           String?
  numeroNfe           String?
  serieNfe            String?
  tributosAproximados Decimal?   @db.Decimal(10, 2)
  troco               Decimal?   @db.Decimal(10, 2)
  mesaId              String?
  mesaNumero          Int?
  criadoEm            DateTime   @default(now())
  atualizadoEm        DateTime   @updatedAt

  negocio    Negocio      @relation(fields: [negocioId], references: [id])
  usuario    Usuario?     @relation(fields: [usuarioId], references: [id])
  mesa       Mesa?        @relation(fields: [mesaId], references: [id], onDelete: SetNull)
  cliente    Cliente?     @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  itens      PedidoItem[]
  pagamentos Pagamento[]
  contasReceber ContaReceber[]

  @@index([negocioId, criadoEm])
  @@index([sessionId])
  @@index([mesaId])
  @@index([clienteId])
  @@map("pedidos")
}

model PedidoItem {
  id              String   @id @default(uuid())
  pedidoId        String
  produtoId       String
  produtoNome     String
  precoUnitario   Decimal  @db.Decimal(10, 2)
  quantidade      Decimal  @default(1) @db.Decimal(10, 3)
  modificadores   Json?    @db.Json
  criadoEm        DateTime @default(now())

  pedido  Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id])

  @@index([pedidoId])
  @@map("pedido_itens")
}

model Pagamento {
  id              String          @id @default(uuid())
  pedidoId        String
  valor           Decimal         @db.Decimal(10, 2)
  metodo          MetodoPagamento
  status          StatusPagamento @default(PENDENTE)
  transacaoId     String?
  dadosPagamento  Json?           @db.Json
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
  @@map("pagamentos")
}
